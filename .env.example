# Supabase — copy to .env.local and fill with your project values.
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for first-owner bootstrap (npm run bootstrap:owner and /bootstrap).
# Server-only. Never expose to the browser or commit real values.
# Also set this in Vercel → Settings → Environment Variables (Production + Preview),
# then redeploy, before using https://soda-os.vercel.app/bootstrap
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional overrides for CLI bootstrap (npm run bootstrap:owner):
# BOOTSTRAP_OWNER_EMAIL=owner@soda.studio
# BOOTSTRAP_OWNER_PASSWORD=Soda-Owner-ChangeMe1!
# BOOTSTRAP_OWNER_NAME=SODA Owner

# Optional — apply Business Core DDL without Dashboard:
# SUPABASE_DB_PASSWORD=your-db-password
# DATABASE_URL=postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres

# Site URL for auth redirects (password reset / invite). Production:
# NEXT_PUBLIC_SITE_URL=https://soda-os.vercel.app

# Auth strictness: unset = strict on Vercel production only.
# SODA_AUTH_STRICT=1   # force login locally
# SODA_AUTH_STRICT=0   # allow owner fallback even on Vercel

# Local/dev only — allow Business Core to run without business_events/audit_log tables.
# Never set in production (ignored when VERCEL_ENV=production).
# ALLOW_IN_MEMORY_BUSINESS_CORE=1

# ONE AUTH ENABLE STEP:
# Supabase Dashboard → Authentication → Providers → Email → Enable.
#
# FIRST OWNER (pick one):
# A) Set SUPABASE_SERVICE_ROLE_KEY → npm run bootstrap:owner
#    OR open /bootstrap on the deployed site after Vercel has the key.
# B) Dashboard: Authentication → Users → Add user (Auto Confirm ON) after
#    SODA_IDENTITY_NAV.sql is applied (first user becomes owner via trigger).
